# ─── Django ───────────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-strong-random-secret-key

# Set to False in production
DJANGO_DEBUG=False

# Comma-separated list of allowed hostnames in production (e.g. myapp.company.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of frontend origins allowed for CORS in production
# e.g. https://myapp.company.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ─── Ingestion API ────────────────────────────────────────────────────────────
INGESTION_API_KEY=change-me-to-a-secret-api-key

# ─── AI Enrichment (Gemini) ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Scraper integration ──────────────────────────────────────────────────────
DQ_API_URL=http://127.0.0.1:8000/api/ingesta-productos/
DQ_API_KEY=change-me-to-a-secret-api-key

# ─── Email ────────────────────────────────────────────────────────────────────
DEFAULT_FROM_EMAIL=noreply@dentalq.es
PURCHASE_REQUEST_NOTIFICATION_EMAIL=info@dentalq.es
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
